[user]
    email = joakim.erelt@gmail.com
    name = Joakim Erelt
[alias]
    co = checkout
    st = status
    dog = log --decorate --oneline --graph --all
    ctags = !.git/hooks/ctags
    st = status
    co = checkout
    dog = log --decorate --oneline --graph --all
    punch = push --force
[color]
    ui = true
[core]
    autocrlf = input
    editor = vim
    excludesfile = ~/.gitignore
[push]
    default = simple
[difftool]
    prompt = false
[init]
    templatedir = ~/.dotfiles/git-template
[mergetool]
    prompt = false

[difftool "sourcetree"]
	cmd = opendiff \"$LOCAL\" \"$REMOTE\"
	path = 
[mergetool "sourcetree"]
	cmd = /opt/homebrew-cask/Caskroom/sourcetree/1.9.7/SourceTree.app/Contents/Resources/opendiff-w.sh \"$LOCAL\" \"$REMOTE\" -ancestor \"$BASE\" -merge \"$MERGED\"
	trustExitCode = true
